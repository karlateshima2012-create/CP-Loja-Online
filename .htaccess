<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. API routes → Laravel backend
  RewriteRule ^api/(.*)$ backend/public/index.php [L,QSA]

  # 2. Static assets (js, css, images, fonts) → serve as-is
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 3. SPA fallback → always serve index.html (React HashRouter)
  RewriteRule ^ index.html [L]
</IfModule>

# Force index.html as the default document (not default.php)
DirectoryIndex index.html

# Security: disable directory listing
Options -Indexes

# Cache control for assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
